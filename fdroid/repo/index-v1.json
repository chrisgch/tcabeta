  "apps": [
    {
      "authorName": "Christian Ghisler",
      "suggestedVersionCode": "89",
      "license": "Unknown",
      "name": "TotalCmd-LAN (Windows shares)",
      "added": 1670143636000,
      "packageName": "com.ghisler.tcplugins.LAN",
      "lastUpdated": 1670143797000,
      "localized": {
        "en-US": {
          "description": "This is a Plugin for Total Commander for Android!\r\nIt does not work standalone!\r\n\r\nDo NOT install if you do not use Total Commander!\r\n\r\nIMPORTANT: If you cannot connect to your server with version 3, then your server probably doesn't support the SMB2 protocol.\r\nSolution: Please open the connection settings by long tap on the connection name. Then disable SMB2. This will use the old SMB1 protocol. Normally the plugin should detect automatically when a server doesn't support SMB2, but some NAS devices seem to react differently.",
          "phoneScreenshots": [
            "lan-plugin1.png"
          ],
          "summary": "SMB (file sharing) plugin for Total Commander"
        }
      },
      "icon": "com.ghisler.tcplugins.LAN.png"
    },
    {
      "authorName": "Christian Ghisler",
      "suggestedVersionCode": "49",
      "license": "Unknown",
      "name": "TotalCmd-SFTP",
      "added": 1670143885000,
      "packageName": "com.ghisler.tcplugins.SFTP",
      "lastUpdated": 1670144010000,
      "localized": {
        "en-US": {
          "description": "This is a Plugin for Total Commander for Android! It does not work standalone!\r\n\r\nDo NOT install if you do not use Total Commander!\r\n\r\nNote: This plugin allows to connect to SFTP servers (file transfer over SSH secure shell). For FTPS (FTP over SSL), please use the separate FTP plugin.\r\n\r\nWhy is this plugin so big? It includes the free sshj library for ssh connections. To support authentication via client certificates, it also has to include libraries from the BouncyCastle project.",
          "phoneScreenshots": [
            "sftpshot1.png",
            "sftpshot2.png"
          ],
          "summary": "SFTP-Plugin for Total Commander"
        }
      },
      "icon": "com.ghisler.tcplugins.SFTP.png"
    },
    {
      "authorName": "Christian Ghisler",
      "suggestedVersionCode": "87",
      "license": "Unknown",
      "name": "TotalCmd-Wifi Transfer",
      "added": 1670145836000,
      "icon": "com.ghisler.tcplugins.wifitransfer.87.png",
      "packageName": "com.ghisler.tcplugins.wifitransfer",
      "lastUpdated": 1670145839000,
      "localized": {
        "en-US": {
          "description": "WiFi transfer plugin and standalone app (does not require Total Commander)\r\n\r\nImportant note: This app does NOT contain any ads. However, it contains a link to Total Commander in the upper right corner if you use a Web Browser to access the files, and this plugin as the server. This is treated as an ad by the Play Store.\r\n\r\nThis plugin/tool supports direct connections via HTTP over WiFi/WLAN between two Android devices, or between Android (Server) and any device or computer with a Web browser or WebDAV client.\r\n\r\nIt creates a local Web+WebDAV server. The server URL can either be scanned as a QR-Code, or entered manually.\r\n\r\nAlthough this is mainly a plugin for Total Commander, it can also be used standalone: Simply select some files in any file manager, or text, or an URL, and then use the \"share\" function to send it to the WiFi plugin. This will start a server and show the URL and QR-Code for the server.\r\n\r\nGreat to transfer data locally between two Android devices without going through the cloud! Your data will never leave your own wireless LAN network.\r\n\r\nNote: Both devices need to be in the same WiFi network. If the sender isn't part of a WiFi network, this tool will offer to create its own access point, or start a WiFi direct connection. Other devices can then connect to this network to transfer data. If you scan the QR-Code from a copy of the WiFi plugin, the connection will be established automatically, and closed automatically when disconnecting.\r\n\r\nUnfortunately Android 10 and newer require the \"Location\" permission to create a WiFi direct server. The app will request this permission only when you try to start a WiFi direct server. It is not needed for normal operation when client and server are on the same network.\r\n\r\nStarting with version 3.4, it's now possible to use a fixed path with user name/password login instead of a random path. It uses DIGEST authentication, so your password is never sent in clear text over the connection. This login method is recommended when connecting regularly to the same device, e.g. when mounting the device as a drive in Windows or MacOS.",
          "phoneScreenshots": [
            "wifi01.png",
            "wifi02.png",
            "wifi03.png",
            "wifi04.png"
          ],
          "summary": "WiFi transfer plugin and standalone app (does not require Total Commander)"
        }
      }
    }
  ],
