  "apps": [
    {
      "authorName": "Christian Ghisler",
      "suggestedVersionCode": "89",
      "license": "Unknown",
      "name": "TotalCmd-LAN (Windows shares)",
      "added": 1670143636000,
      "packageName": "com.ghisler.tcplugins.LAN",
      "lastUpdated": 1670143797000,
      "localized": {
        "en-US": {
          "description": "This is a Plugin for Total Commander for Android!\r\nIt does not work standalone!\r\n\r\nDo NOT install if you do not use Total Commander!\r\n\r\nIMPORTANT: If you cannot connect to your server with version 3, then your server probably doesn't support the SMB2 protocol.\r\nSolution: Please open the connection settings by long tap on the connection name. Then disable SMB2. This will use the old SMB1 protocol. Normally the plugin should detect automatically when a server doesn't support SMB2, but some NAS devices seem to react differently.",
          "phoneScreenshots": [
            "lan-plugin1.png"
          ],
          "summary": "SMB (file sharing) plugin for Total Commander"
        }
      },
      "icon": "com.ghisler.tcplugins.LAN.png"
    },
    {
      "authorName": "Christian Ghisler",
      "suggestedVersionCode": "49",
      "license": "Unknown",
      "name": "TotalCmd-SFTP",
      "added": 1670143885000,
      "packageName": "com.ghisler.tcplugins.SFTP",
      "lastUpdated": 1670144010000,
      "localized": {
        "en-US": {
          "description": "This is a Plugin for Total Commander for Android! It does not work standalone!\r\n\r\nDo NOT install if you do not use Total Commander!\r\n\r\nNote: This plugin allows to connect to SFTP servers (file transfer over SSH secure shell). For FTPS (FTP over SSL), please use the separate FTP plugin.\r\n\r\nWhy is this plugin so big? It includes the free sshj library for ssh connections. To support authentication via client certificates, it also has to include libraries from the BouncyCastle project.",
          "phoneScreenshots": [
            "sftpshot1.png",
            "sftpshot2.png"
          ],
          "summary": "SFTP-Plugin for Total Commander"
        }
      },
      "icon": "com.ghisler.tcplugins.SFTP.png"
    }
  ],
